# BioSentinel Environment Configuration
# Copy to .env and fill in values

# ── App ──────────────────────────────────────
HOST=0.0.0.0
PORT=8000
BIOSENTINEL_DEBUG=false

# ── Database ────────────────────────────────
DB_PATH=data/biosentinel.db

# ── Ingestion ────────────────────────────────
INGESTION_INTERVAL=30

# ── Restricted Data Interface ─────────────────
# Set RESTRICTED_ENABLED=true to enable the classified data plugin layer
RESTRICTED_ENABLED=false
RESTRICTED_ENDPOINT=
RESTRICTED_API_KEY=
